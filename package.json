{
	"name": "ithinkihave",
	"version": "1.0.0",
	"type": "module",
	"main": "index.ts",
	"scripts": {
		"start": "tsx index.ts",
		"test": "node --import tsx/esm --test tests/*.test.ts",
		"typecheck": "tsc --noEmit",
		"formatcheck": "prettier --list-different $(find . -type f | grep -E \".(ts|json|yaml|yml|md)$\" | grep -v node_modules) | xargs -I{} bash -c 'diff --color -u {} <(prettier {})'",
		"format": "prettier . --write",
		"checkall": "npm run test && npm run formatcheck && npm run typecheck && eslint ."
	},
	"repository": "https://github.com/InvalidSE/ithinkihave.git",
	"author": "Taine Reader <taine.reader@gmail.com>",
	"license": "MIT",
	"dependencies": {
		"discord.js": "^14.16.2",
		"dotenv": "^16.4.5",
		"natural": "^8.1.1",
		"sharp": "^0.34.5",
		"tsx": "^4.21.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@eslint/json": "^1.2.0",
		"@eslint/markdown": "^8.0.1",
		"@types/node": "^25.5.2",
		"eslint": "^10.2.0",
		"globals": "^17.5.0",
		"jiti": "^2.6.1",
		"pre-commit": "^1.2.2",
		"prettier": "^3.8.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.2"
	},
	"pre-commit": [
		"checkall"
	]
}
